{
  "info": {
    "name": "InkForge API",
    "description": "InkForge Postman collection generated from current backend controllers.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "用户模块",
      "item": [
        {
          "name": "用户注册",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"username\":\"{{username}}\",\"password\":\"{{password}}\",\"email\":\"{{email}}\"}"},
            "url": "{{baseUrl}}/api/user/register"
          }
        },
        {
          "name": "用户登录",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 200) {",
                "  const json = pm.response.json();",
                "  if (json && json.data) {",
                "    if (json.data.token) pm.collectionVariables.set('token', json.data.token);",
                "    if (json.data.id !== undefined && json.data.id !== null) pm.collectionVariables.set('userId', String(json.data.id));",
                "    if (json.data.username) pm.collectionVariables.set('currentUsername', json.data.username);",
                "  }",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"username\":\"{{username}}\",\"password\":\"{{password}}\"}"},
            "url": "{{baseUrl}}/api/user/login"
          }
        },
        {
          "name": "获取当前用户信息",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/user/info"
          }
        },
        {
          "name": "更新头像",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"avatar\":\"{{avatarUrl}}\"}"},
            "url": "{{baseUrl}}/api/user/info"
          }
        },
        {
          "name": "获取用户主页",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/user/{{profileUserId}}/profile"
          }
        },
        {
          "name": "搜索用户",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/user/search?page=1&size=20&keyword={{searchKeyword}}"
          }
        },
        {
          "name": "更新个人简介",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"bio\":\"这是我在 Postman 里更新的简介。\"}"},
            "url": "{{baseUrl}}/api/user/bio"
          }
        },
        {
          "name": "发送邮箱验证码",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\":\"{{newEmail}}\",\"purpose\":\"bind\"}"},
            "url": "{{baseUrl}}/api/user/email/send-code"
          }
        },
        {
          "name": "绑定邮箱",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\":\"{{newEmail}}\",\"code\":\"{{emailCode}}\"}"},
            "url": "{{baseUrl}}/api/user/email/bind"
          }
        },
        {
          "name": "更换邮箱",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\":\"{{newEmail}}\",\"code\":\"{{emailCode}}\"}"},
            "url": "{{baseUrl}}/api/user/email/change"
          }
        },
        {
          "name": "发送重置密码验证码",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\":\"{{email}}\"}"},
            "url": "{{baseUrl}}/api/user/password/send-code"
          }
        },
        {
          "name": "重置密码",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\":\"{{email}}\",\"code\":\"{{emailCode}}\",\"newPassword\":\"{{newPassword}}\"}"},
            "url": "{{baseUrl}}/api/user/password/reset"
          }
        },
        {
          "name": "修改用户名",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"newUsername\":\"{{newUsername}}\"}"},
            "url": "{{baseUrl}}/api/user/username"
          }
        },
        {
          "name": "修改密码",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"oldPassword\":\"{{password}}\",\"newPassword\":\"{{newPassword}}\"}"},
            "url": "{{baseUrl}}/api/user/password"
          }
        },
        {
          "name": "发送注销验证码",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "POST",
            "url": "{{baseUrl}}/api/user/account/send-delete-code"
          }
        },
        {
          "name": "注销账户",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "DELETE",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"password\":\"{{password}}\",\"code\":\"{{emailCode}}\"}"},
            "url": "{{baseUrl}}/api/user/account"
          }
        }
      ]
    },
    {
      "name": "内容模块",
      "item": [
        {
          "name": "创建内容",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 200) {",
                "  const json = pm.response.json();",
                "  if (json && json.data !== undefined && json.data !== null) pm.collectionVariables.set('contentId', String(json.data));",
                "}"
              ]
            }
          }],
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"title\":\"我的第一篇 Postman 测试文章\",\"content\":\"这是我用 Postman 创建的一篇内容。\",\"type\":\"散文\",\"coverImage\":null,\"tagIds\":[],\"customTags\":[\"测试记录\"],\"isDraft\":false,\"visibility\":\"public\"}"},
            "url": "{{baseUrl}}/api/content/create"
          }
        },
        {
          "name": "获取内容列表",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/content/list?page=1&size=20"
          }
        },
        {
          "name": "排行榜",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/content/rank?rankType=reads"
          }
        },
        {
          "name": "首页热门横幅",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/content/hot-banner"
          }
        },
        {
          "name": "获取内容详情",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/content/{{contentId}}"
          }
        },
        {
          "name": "更新内容",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"title\":\"我的第一篇 Postman 测试文章（已更新）\",\"content\":\"这是更新后的正文。\",\"type\":\"散文\",\"coverImage\":null,\"tagIds\":[],\"customTags\":[\"更新测试\"],\"isDraft\":false,\"visibility\":\"public\"}"},
            "url": "{{baseUrl}}/api/content/{{contentId}}"
          }
        },
        {
          "name": "删除内容",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "DELETE",
            "url": "{{baseUrl}}/api/content/{{contentId}}"
          }
        },
        {
          "name": "我的内容",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/content/my?page=1&size=10"
          }
        },
        {
          "name": "我的草稿",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/content/my/drafts?page=1&size=10"
          }
        },
        {
          "name": "我的点赞",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/content/my/likes?page=1&size=20"
          }
        },
        {
          "name": "获取用户作品",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/content/user/{{profileUserId}}?page=1&size=20"
          }
        },
        {
          "name": "点赞 / 取消点赞",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "POST",
            "url": "{{baseUrl}}/api/content/{{contentId}}/like"
          }
        }
      ]
    },
    {
      "name": "评论模块",
      "item": [
        {
          "name": "发表评论",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"contentId\":{{contentId}},\"content\":\"这篇内容很适合拿来练习接口测试。\"}"},
            "url": "{{baseUrl}}/api/comment"
          }
        },
        {
          "name": "获取评论列表",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/comment/{{contentId}}?page=1&size=20"
          }
        },
        {
          "name": "删除评论",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "DELETE",
            "url": "{{baseUrl}}/api/comment/{{commentId}}"
          }
        }
      ]
    },
    {
      "name": "章节模块",
      "item": [
        {
          "name": "新增章节",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"contentId\":{{contentId}},\"chapterTitle\":\"第一章 初见\",\"chapterContent\":\"章节正文内容。\",\"chapterOrder\":1}"},
            "url": "{{baseUrl}}/api/chapter"
          }
        },
        {
          "name": "获取章节列表",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/chapter/{{contentId}}"}
        },
        {
          "name": "更新章节",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"chapterTitle\":\"第一章 重写\",\"chapterContent\":\"更新后的章节正文。\"}"},
            "url": "{{baseUrl}}/api/chapter/{{chapterId}}"
          }
        },
        {
          "name": "删除章节",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "DELETE",
            "url": "{{baseUrl}}/api/chapter/{{chapterId}}"
          }
        }
      ]
    },
    {
      "name": "收藏模块",
      "item": [
        {
          "name": "添加收藏",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "POST",
            "url": "{{baseUrl}}/api/favorite/{{contentId}}"
          }
        },
        {
          "name": "取消收藏",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "DELETE",
            "url": "{{baseUrl}}/api/favorite/{{contentId}}"
          }
        },
        {
          "name": "获取收藏列表",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/favorite/list?page=1&size=10"
          }
        },
        {
          "name": "检查是否已收藏",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/favorite/check/{{contentId}}"
          }
        }
      ]
    },
    {
      "name": "关注模块",
      "item": [
        {
          "name": "关注用户",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "POST",
            "url": "{{baseUrl}}/api/follow/{{followUserId}}"
          }
        },
        {
          "name": "取消关注",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "DELETE",
            "url": "{{baseUrl}}/api/follow/{{followUserId}}"
          }
        },
        {
          "name": "移除粉丝",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "DELETE",
            "url": "{{baseUrl}}/api/follow/follower/{{followUserId}}"
          }
        },
        {
          "name": "检查关注状态",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/follow/check/{{followUserId}}"
          }
        },
        {
          "name": "获取粉丝列表",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/follow/{{profileUserId}}/followers?page=1&size=20"}
        },
        {
          "name": "获取关注列表",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/follow/{{profileUserId}}/following?page=1&size=20"}
        }
      ]
    },
    {
      "name": "标签模块",
      "item": [
        {
          "name": "获取标签列表",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/tag/list"}
        },
        {
          "name": "创建自定义标签",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 200) {",
                "  const json = pm.response.json();",
                "  if (json && json.data && json.data.id !== undefined && json.data.id !== null) pm.collectionVariables.set('tagId', String(json.data.id));",
                "}"
              ]
            }
          }],
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"tagName\":\"{{customTagName}}\"}"},
            "url": "{{baseUrl}}/api/tag/create"
          }
        },
        {
          "name": "获取热门标签",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/tag/hot?limit=20"}
        }
      ]
    },
    {
      "name": "上传模块",
      "item": [
        {
          "name": "上传图片",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "POST",
            "body": {"mode": "formdata", "formdata": [{"key": "file", "type": "file", "src": ""}]},
            "url": "{{baseUrl}}/api/upload/image"
          }
        }
      ]
    },
    {
      "name": "AI 模块",
      "item": [
        {
          "name": "AI 续写",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"content\":\"故事开头：夜里十二点，图书馆的灯还亮着。\"}"},
            "url": "{{baseUrl}}/api/ai/generate"
          }
