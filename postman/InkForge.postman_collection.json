            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"content\":\"文章内容。\",\"question\":\"这篇文章的核心主题是什么？\"}"},
            "url": "{{baseUrl}}/api/ai/qa"
          }
        }
      ]
    },
    {
      "name": "管理员模块",
      "item": [
        {
          "name": "管理员 - 获取用户列表",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/users?page=1&size=10"
          }
        },
        {
          "name": "管理员 - 更新用户状态",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"status\":\"禁用\"}"},
            "url": "{{baseUrl}}/api/admin/users/{{adminUserId}}/status"
          }
        },
        {
          "name": "管理员 - 删除用户",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "DELETE",
            "url": "{{baseUrl}}/api/admin/users/{{adminUserId}}"
          }
        },
        {
          "name": "管理员 - 获取内容列表",
